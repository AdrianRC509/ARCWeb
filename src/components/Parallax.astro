---
interface Layer {
  src: string;
  speed: number;
  zIndex?: number;
  alt?: string;
}

interface Props {
  layers: Layer[];
  height?: string;
  class?: string;
  fadeColor?: string;
}

const { layers, height = "100vh", class: className, fadeColor } = Astro.props;
---

<section class:list={["parallax", className]} style={`height: ${height};`}>
  {layers.map((layer, i) => (
    <img
      src={layer.src}
      class="parallax-layer"
      data-speed={layer.speed}
      style={`z-index: ${layer.zIndex ?? i};`}
      alt={layer.alt ?? ""}
      aria-hidden={layer.alt ? "false" : "true"}
      loading="eager"
      decoding="async"
    />
  ))}
  {fadeColor && (
    <div class="parallax-fade" style={`background: linear-gradient(to bottom, transparent, ${fadeColor});`} aria-hidden="true" />
  )}
  <div class="parallax-content">
    <slot />
  </div>
</section>

<style>
  .parallax {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--night-sky-top);
  }
  .parallax-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: bottom center;
    will-change: transform;
    pointer-events: none;
    user-select: none;
  }
  /* Fade the bottom edge of every layer except the sky (first child).
     When layers translate up during scroll, the transparent tail hides the
     hard SVG border — the sky behind shows through instead. */
  .parallax-layer:not(:first-child) {
    mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 80%, transparent 100%);
  }
  .parallax-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 18%;
    z-index: 50;
    pointer-events: none;
  }
  .parallax-content {
    position: relative;
    z-index: 100;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .parallax-layer { transform: none !important; }
  }
</style>

<script>
  type LayerEl = HTMLImageElement & { dataset: { speed: string } };

  function initParallax(): void {
    const layers = document.querySelectorAll<LayerEl>(".parallax-layer");
    if (layers.length === 0) return;

    let ticking = false;

    const update = (): void => {
      const y = window.scrollY;
      layers.forEach((el) => {
        const speed = parseFloat(el.dataset.speed) || 0;
        el.style.transform = `translate3d(0, ${-y * speed}px, 0)`;
      });
      ticking = false;
    };

    const onScroll = (): void => {
      if (!ticking) {
        requestAnimationFrame(update);
        ticking = true;
      }
    };

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) return;

    window.addEventListener("scroll", onScroll, { passive: true });
    update();
  }

  initParallax();
  document.addEventListener("astro:page-load", initParallax);
</script>
