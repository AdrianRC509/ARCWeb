---
import "../styles/global.css";
import ParallaxScene from "../components/ParallaxScene.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Adrian Reyes</title>
  </head>
  <body>

    <nav class="sidenav" aria-label="Page sections">
      <div class="sidenav-main">
        <a href="#about">About</a>
        <a href="#projects">Projects</a>
        <a href="#skills">Skills</a>
      </div>
      <a href="#top" class="sidenav-backtop">↑ Top</a>
    </nav>

    <div id="top">
      <ParallaxScene />
    </div>

    <main>
      <section id="about" class="content-section">
        <h2>About</h2>
        <p>Add your about content here.</p>
      </section>

      <section id="projects" class="content-section">
        <h2>Projects</h2>
        <p>Add your projects here.</p>
      </section>

      <section id="skills" class="content-section">
        <h2>Skills</h2>
        <p>Add your skills here.</p>
      </section>
    </main>

  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
  body {
    margin: 0;
    background: #1e1a2e;
    color: var(--text-primary);
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* ── Side nav ── */
  .sidenav {
    position: fixed;
    left: 1.5rem;
    top: 2.5rem;
    z-index: 200;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    border-left: 1px solid rgba(168, 150, 212, 0.2);
    padding-left: 0.875rem;
  }

  .sidenav-main {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .sidenav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color 0.2s, text-shadow 0.2s;
    line-height: 1;
  }
  .sidenav a:hover {
    color: var(--text-primary);
    text-shadow: 0 0 12px rgba(201, 184, 255, 0.4);
  }

  .sidenav-backtop {
    display: none;
  }
  .sidenav.scrolled .sidenav-main {
    display: none;
  }
  .sidenav.scrolled .sidenav-backtop {
    display: block;
  }

  /* ── Content sections ── */
  .content-section {
    min-height: 100vh;
    padding: 6rem 2rem;
    max-width: 820px;
    margin: 0 auto;
    scroll-margin-top: 2rem;
  }

  .content-section h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.75rem;
    color: var(--text-primary);
    text-shadow: 0 2px 15px rgba(201, 184, 255, 0.1);
  }


  .content-section p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 62ch;
    margin: 0;
  }

  @media (max-width: 640px) {
    .sidenav { display: none; }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('.sidenav');

  function update(): void {
    if (!nav) return;
    nav.classList.toggle('scrolled', window.scrollY > window.innerHeight * 0.8);
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
